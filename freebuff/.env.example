# =============================================================================
# AIGENEV7 - Environment Configuration
# =============================================================================
# At least ONE provider API key is required for inference.
# Copy this file to .env and fill in your keys.
#
# Get API keys:
#   Anthropic:  https://console.anthropic.com/
#   DeepSeek:   https://platform.deepseek.com/
#   OpenAI:     https://platform.openai.com/
#   Google:     https://aistudio.google.com/apikey
#   OpenRouter: https://openrouter.ai/keys
#   Moonshot:   https://platform.moonshot.cn/
#   xAI (Grok): https://console.x.ai/
#   Ollama:     https://ollama.com/ (local, no real key needed - use "ollama")
# =============================================================================

# ── Required (at least one) ──────────────────────────────────────────────

# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...
# OPENROUTER_API_KEY=sk-or-...
# MOONSHOT_API_KEY=sk-...
# XAI_API_KEY=xai-...
# OLLAMA_API_KEY=ollama

# ── Optional ─────────────────────────────────────────────────────────────

# Default model to use when none specified
# AIGENEV7_DEFAULT_MODEL=deepseek-v4-pro

# Maximum output tokens ("Infinity" for unlimited)
# AIGENEV7_MAX_TOKENS=Infinity

# Enable uncensored mode (true = no content filters)
# AIGENEV7_UNCENSORED=true

# Enable streaming responses
# AIGENEV7_STREAM=true

# Temperature (0.0 - 2.0)
# AIGENEV7_TEMPERATURE=0.7
